{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wispy Template",
  "scopeName": "text.html.wispy",
  "patterns": [
    { "include": "#wispy-comment" },
    { "include": "#wispy-raw-block" },
    { "include": "#wispy-tag" },
    { "include": "#wispy-output" },
    { "include": "text.html.basic" }
  ],
  "repository": {
    "wispy-comment": {
      "name": "comment.block.wispy",
      "begin": "\\{#-?",
      "end": "-?#\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.wispy" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.wispy" }
      }
    },

    "wispy-raw-block": {
      "begin": "(\\{%-?)\\s*(raw)\\s*(-?%\\})",
      "end": "(\\{%-?)\\s*(endraw)\\s*(-?%\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.tag.begin.wispy" },
        "2": { "name": "keyword.control.raw.wispy" },
        "3": { "name": "punctuation.section.tag.end.wispy" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.tag.begin.wispy" },
        "2": { "name": "keyword.control.raw.wispy" },
        "3": { "name": "punctuation.section.tag.end.wispy" }
      },
      "contentName": "string.unquoted.raw.wispy"
    },

    "wispy-tag": {
      "begin": "(\\{%-?)",
      "end": "(-?%\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.tag.begin.wispy" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.tag.end.wispy" }
      },
      "patterns": [
        { "include": "#wispy-tag-keywords" },
        { "include": "#wispy-expression" }
      ]
    },

    "wispy-output": {
      "begin": "(\\{\\{-?)",
      "end": "(-?\\}\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.embedded.begin.wispy" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.embedded.end.wispy" }
      },
      "patterns": [
        { "include": "#wispy-expression" }
      ]
    },

    "wispy-tag-keywords": {
      "patterns": [
        {
          "match": "\\b(if|elif|else|endif|unless|endunless)\\b",
          "name": "keyword.control.conditional.wispy"
        },
        {
          "match": "\\b(for|in|empty|endfor)\\b",
          "name": "keyword.control.loop.wispy"
        },
        {
          "match": "\\b(set|with|endwith|capture|endcapture)\\b",
          "name": "keyword.control.assignment.wispy"
        },
        {
          "match": "\\b(macro|endmacro|call|endcall)\\b",
          "name": "keyword.control.macro.wispy"
        },
        {
          "match": "\\b(extends|block|endblock|include|render|import|as)\\b",
          "name": "keyword.control.composition.wispy"
        },
        {
          "match": "\\b(component|endcomponent|props|slot|endslot|fill|endfill)\\b",
          "name": "keyword.control.component.wispy"
        },
        {
          "match": "\\b(asset|endasset|meta|hoist|endhoist)\\b",
          "name": "keyword.control.web.wispy"
        },
        {
          "match": "\\b(raw|endraw)\\b",
          "name": "keyword.control.raw.wispy"
        },
        {
          "match": "\\b(isolated)\\b",
          "name": "keyword.other.modifier.wispy"
        }
      ]
    },

    "wispy-expression": {
      "patterns": [
        { "include": "#wispy-string-double" },
        { "include": "#wispy-string-single" },
        { "include": "#wispy-number" },
        { "include": "#wispy-boolean" },
        { "include": "#wispy-null" },
        { "include": "#wispy-logical-operator" },
        { "include": "#wispy-filter" },
        { "include": "#wispy-builtin-function" },
        { "include": "#wispy-comparison-operator" },
        { "include": "#wispy-concatenation-operator" },
        { "include": "#wispy-arithmetic-operator" },
        { "include": "#wispy-assignment-operator" },
        { "include": "#wispy-accessor" },
        { "include": "#wispy-variable" }
      ]
    },

    "wispy-string-double": {
      "name": "string.quoted.double.wispy",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.wispy"
        }
      ]
    },

    "wispy-string-single": {
      "name": "string.quoted.single.wispy",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.wispy"
        }
      ]
    },

    "wispy-number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.wispy"
    },

    "wispy-boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.wispy"
    },

    "wispy-null": {
      "match": "\\b(nil|null)\\b",
      "name": "constant.language.null.wispy"
    },

    "wispy-logical-operator": {
      "match": "\\b(and|or|not)\\b",
      "name": "keyword.operator.logical.wispy"
    },

    "wispy-filter": {
      "match": "\\|\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "0": {
          "patterns": [
            {
              "match": "\\|",
              "name": "keyword.operator.filter.wispy"
            },
            {
              "match": "\\b(upcase|downcase|capitalize|titlecase|trim|lstrip|rstrip|replace|replace_all|prepend|append|truncate|truncate_words|split|strip_html|strip_newlines|newline_to_br|nl2br|escape|h|url_encode|url_decode|base64_encode|base64_decode|slugify|markdown|safe|json|default|round|ceil|floor|abs|plus|minus|times|divided_by|modulo|join|first|last|size|length|reverse|sort|uniq|compact|flatten|map|where|reject|sum|min|max|slice|push|keys|values)\\b",
              "name": "support.function.filter.wispy"
            },
            {
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
              "name": "support.function.filter.wispy"
            }
          ]
        }
      }
    },

    "wispy-builtin-function": {
      "match": "\\b(range|caller|super)\\s*(?=\\()",
      "captures": {
        "1": { "name": "support.function.builtin.wispy" }
      }
    },

    "wispy-comparison-operator": {
      "match": "==|!=|<=|>=|<|>",
      "name": "keyword.operator.comparison.wispy"
    },

    "wispy-concatenation-operator": {
      "match": "~",
      "name": "keyword.operator.concatenation.wispy"
    },

    "wispy-arithmetic-operator": {
      "match": "[+\\-*/%]",
      "name": "keyword.operator.arithmetic.wispy"
    },

    "wispy-assignment-operator": {
      "match": "(?<![=!<>])=(?!=)",
      "name": "keyword.operator.assignment.wispy"
    },

    "wispy-accessor": {
      "match": "\\.",
      "name": "punctuation.accessor.wispy"
    },

    "wispy-variable": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.wispy"
    }
  }
}
