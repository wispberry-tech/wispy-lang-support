{
  "name": "tree-sitter-grov",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Wispy Grove templates",
  "license": "MIT",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "parser",
    "grov",
    "wispy-grove",
    "template"
  ],
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "text.html.grov",
      "injection-regex": "grov",
      "file-types": [
        "grov"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}
